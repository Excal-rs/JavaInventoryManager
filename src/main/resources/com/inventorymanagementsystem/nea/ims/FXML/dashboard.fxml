<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="800.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/23.0.1"
            fx:controller="com.inventorymanagementsystem.nea.ims.Controllers.DashboardController">
    <children>
        <GridPane prefHeight="800.0" prefWidth="1280.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="825.0" minWidth="10.0" prefWidth="427.0"/>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="773.0" minWidth="10.0" prefWidth="427.0"/>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="395.0" minWidth="10.0" prefWidth="426.0"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints maxHeight="120.0" minHeight="0.0" prefHeight="0.0" vgrow="SOMETIMES"/>
                <RowConstraints maxHeight="450.0" minHeight="10.0" prefHeight="450.0" vgrow="SOMETIMES"/>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
            </rowConstraints>
            <children>
                <TableView fx:id="itemsTable" prefHeight="464.0" prefWidth="1264.0" GridPane.columnSpan="3"
                           GridPane.rowIndex="1" GridPane.rowSpan="2">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                    <GridPane.margin>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
                    </GridPane.margin>
                </TableView>
                <Button fx:id="addItemBtn" mnemonicParsing="false" onAction="#switchToAddItemScene" text="Add Item"
                        GridPane.halignment="LEFT" GridPane.rowIndex="3" GridPane.valignment="TOP">
                    <GridPane.margin>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
                    </GridPane.margin>
                </Button>
                <Rectangle arcHeight="20.0" arcWidth="20.0" fill="DODGERBLUE" height="90.0" stroke="BLACK"
                           strokeType="INSIDE" styleClass="infoContainer" width="234.0" GridPane.columnIndex="1"
                           GridPane.halignment="CENTER" GridPane.rowIndex="3" GridPane.valignment="CENTER">
                    <GridPane.margin>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
                    </GridPane.margin>
                </Rectangle>
                <Label fx:id="titleLbl" text="Dashboard" GridPane.halignment="LEFT" GridPane.valignment="TOP">
                    <GridPane.margin>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
                    </GridPane.margin>
                </Label>
                <Button fx:id="logoutBtn" mnemonicParsing="false" onAction="#logout" text="Log out"
                        GridPane.columnIndex="2" GridPane.halignment="RIGHT" GridPane.valignment="TOP">
                    <GridPane.margin>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
                    </GridPane.margin>
                </Button>
                <Rectangle arcHeight="20.0" arcWidth="20.0" fill="DODGERBLUE" height="90.0" stroke="BLACK"
                           strokeType="INSIDE" styleClass="infoContainer" width="234.0" GridPane.columnIndex="2"
                           GridPane.halignment="CENTER" GridPane.rowIndex="3" GridPane.valignment="CENTER">
                    <GridPane.margin>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
                    </GridPane.margin>
                </Rectangle>
                <Label styleClass="infoTitle" text="Total Item quantity" GridPane.columnIndex="1"
                       GridPane.halignment="CENTER" GridPane.rowIndex="3" GridPane.valignment="TOP">
                    <GridPane.margin>
                        <Insets bottom="23.0" left="23.0" right="23.0" top="23.0"/>
                    </GridPane.margin>
                </Label>
                <Label styleClass="infoTitle" text="Total price" GridPane.columnIndex="2" GridPane.halignment="CENTER"
                       GridPane.rowIndex="3" GridPane.valignment="TOP">
                    <GridPane.margin>
                        <Insets bottom="23.0" left="23.0" right="23.0" top="23.0"/>
                    </GridPane.margin>
                </Label>
                <Label fx:id="totalQuantLbl" styleClass="infoValue" text="1,000,000,000" GridPane.columnIndex="1"
                       GridPane.halignment="CENTER" GridPane.rowIndex="3" GridPane.valignment="CENTER">
                    <GridPane.margin>
                        <Insets/>
                    </GridPane.margin>
                </Label>
                <Label fx:id="totalPriceLbl" styleClass="infoValue" text="£1,000,000,000" GridPane.columnIndex="2"
                       GridPane.halignment="CENTER" GridPane.rowIndex="3" GridPane.valignment="CENTER">
                    <GridPane.margin>
                        <Insets/>
                    </GridPane.margin>
                </Label>
                <TextField fx:id="searchField" GridPane.halignment="RIGHT" GridPane.rowIndex="3"
                           GridPane.valignment="TOP">
                    <GridPane.margin>
                        <Insets bottom="20.0" left="120.0" right="40.0" top="20.0"/>
                    </GridPane.margin>
                </TextField>
                <Button fx:id="searchBtn" mnemonicParsing="false" onAction="#searchTable" text="🔍"
                        GridPane.halignment="RIGHT" GridPane.rowIndex="3" GridPane.valignment="TOP">
                    <GridPane.margin>
                        <Insets top="20.0"/>
                    </GridPane.margin>
                </Button>
            </children>
        </GridPane>
    </children>
</AnchorPane>
